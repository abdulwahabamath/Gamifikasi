<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Math Gamification - Instant Feedback Mode</title>
    <style>
        :root {
            --primary: #4e54c8;
            --secondary: #8f94fb;
            --success: #2ecc71;
            --danger: #e74c3c;
            --bg-gradient: linear-gradient(135deg, #4e54c8, #8f94fb);
            --card-bg: #ffffff;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            color: #333;
        }

        .game-container {
            background: var(--card-bg);
            width: 100%;
            max-width: 800px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            padding: 30px;
            position: relative;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #f0f2f5;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }

        .level-badge {
            background: var(--primary);
            color: white;
            padding: 6px 15px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 0.9rem;
        }

        .score-board {
            font-size: 1.1rem;
            font-weight: bold;
            color: var(--primary);
        }

        .question-card {
            display: none;
        }

        .question-card.active {
            display: block;
            animation: fadeIn 0.4s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h2 {
            margin-bottom: 15px;
            font-size: 1.4rem;
            color: #2c3e50;
        }

        p.instruction {
            color: #7f8c8d;
            font-size: 0.95rem;
            margin-bottom: 20px;
            line-height: 1.5;
        }

        /* Input Styles */
        .math-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 20px;
        }

        .math-item {
            background: #f8fafc;
            padding: 12px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border: 2px solid #e2e8f0;
            transition: all 0.3s;
        }

        .math-item.correct {
            background: #e8f5e9;
            border-color: var(--success);
        }

        .math-item.wrong {
            background: #ffebee;
            border-color: var(--danger);
        }

        .math-item span {
            font-size: 1.1rem;
            font-weight: 600;
        }

        input[type="number"], input[type="text"] {
            width: 80px;
            padding: 8px;
            border: 2px solid #cbd5e1;
            border-radius: 6px;
            font-size: 1.1rem;
            text-align: center;
            outline: none;
        }

        input:disabled {
            background: #f1f5f9;
            color: #333;
        }

        /* Graph/Circle Sorting Component */
        .circle-layout {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 20px 0;
        }

        .circle-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            padding: 10px;
            border-radius: 8px;
            border: 2px solid transparent;
        }

        .circle-box span {
            font-size: 0.8rem;
            color: #64748b;
            font-weight: bold;
        }

        /* Options for MCQs */
        .options-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-top: 15px;
        }

        .option-btn {
            background: #f1f5f9;
            border: 2px solid #e2e8f0;
            padding: 12px 20px;
            border-radius: 10px;
            cursor: pointer;
            text-align: left;
            font-size: 1rem;
            font-weight: 500;
            transition: all 0.2s;
        }

        .option-btn.selected {
            background: #cbd5e1;
            border-color: #94a3b8;
        }

        .option-btn.correct-opt {
            background: #2ecc71 !important;
            color: white;
            border-color: #27ae60;
        }

        .option-btn.wrong-opt {
            background: #e74c3c !important;
            color: white;
            border-color: #c0392b;
        }

        /* Feedback Banner */
        .feedback-banner {
            margin-top: 15px;
            padding: 12px;
            border-radius: 10px;
            display: none;
            font-weight: bold;
            text-align: center;
            animation: fadeIn 0.3s;
        }

        .feedback-banner.show-correct {
            display: block;
            background: #d4edda;
            color: #155724;
        }

        .feedback-banner.show-wrong {
            display: block;
            background: #f8d7da;
            color: #721c24;
        }

        /* Action Buttons */
        .actions {
            margin-top: 30px;
            display: flex;
            justify-content: flex-end;
        }

        .btn-action {
            background: var(--primary);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-action.next-state {
            background: var(--success);
        }

        .pattern-svg {
            display: block;
            margin: 20px auto;
            max-width: 100%;
            height: auto;
        }

        .results-screen {
            text-align: center;
            display: none;
        }
    </style>
</head>
<body>

<div class="game-container">
    <header>
        <div id="level-indicator" class="level-badge">LEVEL 1: BASIC</div>
        <div class="score-board">Skor: <span id="live-score">0</span></div>
    </header>

    <div class="question-card active" id="q1">
        <h2>№ 1: Cobalah!</h2>
        <p class="instruction">Isilah semua titik-titik di bawah ini dengan jawaban yang benar.</p>
        <div class="math-grid">
            <div class="math-item" id="box_l1_q1"><span>42 + 20 =</span><input type="number" id="l1_q1"></div>
            <div class="math-item" id="box_l1_q2"><span>65 - 30 =</span><input type="number" id="l1_q2"></div>
            <div class="math-item" id="box_l1_q3"><span>56 + 13 =</span><input type="number" id="l1_q3"></div>
            <div class="math-item" id="box_l1_q4"><span>72 - 25 =</span><input type="number" id="l1_q4"></div>
            <div class="math-item" id="box_l1_q5"><span>43 + 26 =</span><input type="number" id="l1_q5"></div>
            <div class="math-item" id="box_l1_q6"><span>[ ] + 25 = 60</span><input type="number" id="l1_q6"></div>
            <div class="math-item" id="box_l1_q7"><span>75 - [ ] = 30</span><input type="number" id="l1_q7"></div>
            <div class="math-item" id="box_l1_q8"><span>[ ] + 20 = 45</span><input type="number" id="l1_q8"></div>
            <div class="math-item" id="box_l1_q9"><span>50 - [ ] = 30</span><input type="number" id="l1_q9"></div>
            <div class="math-item" id="box_l1_q10"><span>[ ] - 20 = 23</span><input type="number" id="l1_q10"></div>
        </div>
    </div>

    <div class="question-card" id="q2">
        <h2>№ 2: Logika Struktur Angka</h2>
        <p class="instruction">Susunlah angka-angka <b>4, 14, dan 26</b> ke dalam lingkaran agar setiap tanda panah bergerak dari angka <b>TERBESAR ke TERKECIL</b>.</p>
        
        <svg class="pattern-svg" width="160" height="160" viewBox="0 0 200 200">
            <circle cx="50" cy="50" r="25" fill="#a7f3d0" stroke="#047857" stroke-width="2"/>
            <circle cx="50" cy="150" r="25" fill="#a7f3d0" stroke="#047857" stroke-width="2"/>
            <circle cx="150" cy="100" r="25" fill="#a7f3d0" stroke="#047857" stroke-width="2"/>
            <path d="M 50 80 L 50 120" stroke="#333" stroke-width="2" marker-end="url(#arrow)"/>
            <path d="M 75 55 L 125 90" stroke="#333" stroke-width="2" marker-end="url(#arrow)"/>
            <path d="M 75 145 L 125 110" stroke="#333" stroke-width="2" marker-end="url(#arrow)"/>
            <defs>
                <marker id="arrow" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                    <path d="M 0 1 L 10 5 L 0 9 z" fill="#333"/>
                </marker>
            </defs>
        </svg>

        <div class="circle-layout">
            <div class="circle-box" id="box_l1_top"><span>Atas</span><input type="number" id="l1_sort_top"></div>
            <div class="circle-box" id="box_l1_bottom"><span>Bawah</span><input type="number" id="l1_sort_bottom"></div>
            <div class="circle-box" id="box_l1_right"><span>Kanan</span><input type="number" id="l1_sort_right"></div>
        </div>
    </div>

    <div class="question-card" id="q3">
        <h2>№ 3: Teka-Teki Alur Hewan</h2>
        <p class="instruction">Perhatikan baris dan kolom dengan pola pengurangan:<br>
        Baris Horizontal: 30 &rarr; 25 &rarr; Zebra &rarr; 15 (Berkurang 5)<br>
        Kolom Vertikal: Singa &rarr; 15 &rarr; 12 &rarr; 9 &rarr; Rakun &rarr; Bebek &rarr; 3 (Berkurang 3)<br><br>
        <b>Berapakah hasil dari: Zebra + Bebek + Rakun + Singa?</b></p>
        <div class="math-item" id="box_l1_animal" style="justify-content: center; gap: 15px;">
            <span>Jawaban Total Akhir:</span>
            <input type="number" id="l1_animal_sum" style="width: 120px;">
        </div>
    </div>

    <div class="question-card" id="q4">
        <h2>№ 4: Temukan Digit yang Hilang!</h2>
        <p class="instruction">Tentukan angka satuan yang tepat untuk menyelesaikan pengurangan bersusun ini: <b>65 - 3[?] = 31</b></p>
        <div class="math-item" id="box_l1_missing" style="justify-content: center; gap: 15px;">
            <span>Digit yang hilang ([?]):</span>
            <input type="number" id="l1_missing_digit">
        </div>
    </div>

    <div class="question-card" id="q5">
        <h2>№ 1 (Level 2): Operasi Standard</h2>
        <p class="instruction">Isilah kotak dengan jawaban matematika yang benar.</p>
        <div class="math-grid">
            <div class="math-item" id="box_l2_q1"><span>47 + 38 =</span><input type="number" id="l2_q1"></div>
            <div class="math-item" id="box_l2_q2"><span>86 - 29 =</span><input type="number" id="l2_q2"></div>
            <div class="math-item" id="box_l2_q3"><span>46 + 39 =</span><input type="number" id="l2_q3"></div>
            <div class="math-item" id="box_l2_q4"><span>73 - 48 =</span><input type="number" id="l2_q4"></div>
            <div class="math-item" id="box_l2_q5"><span>68 + 25 =</span><input type="number" id="l2_q5"></div>
            <div class="math-item" id="box_l2_q6"><span>67 + 23 =</span><input type="number" id="l2_q6"></div>
            <div class="math-item" id="box_l2_q7"><span>76 - [ ] = 28</span><input type="number" id="l2_q7"></div>
            <div class="math-item" id="box_l2_q8"><span>84 - 56 =</span><input type="number" id="l2_q8"></div>
            <div class="math-item" id="box_l2_q9"><span>[ ] + 48 = 92</span><input type="number" id="l2_q9"></div>
            <div class="math-item" id="box_l2_q10"><span>95 - [ ] = 47</span><input type="number" id="l2_q10"></div>
            <div class="math-item" id="box_l2_q11"><span>[ ] + 56 = 97</span><input type="number" id="l2_q11"></div>
            <div class="math-item" id="box_l2_q12"><span>[ ] - 36 = 47</span><input type="number" id="l2_q12"></div>
            <div class="math-item" id="box_l2_q13"><span>88 - [ ] = 39</span><input type="number" id="l2_q13"></div>
            <div class="math-item" id="box_l2_q14"><span>[ ] - 57 = 26</span><input type="number" id="l2_q14"></div>
        </div>
    </div>

    <div class="question-card" id="q6">
        <h2>№ 2 (Level 2): Logika Sakelar</h2>
        <p class="instruction">Maria menekan sebuah sakelar 7 kali saat sakelar dalam keadaan <b>MENYALA</b>. Setelah Maria pergi, kakaknya menekan sakelar yang sama 15 kali. Apakah sakelar tersebut sekarang dalam keadaan MENYALA atau MATI?</p>
        <div class="options-container" id="opts_q6">
            <button class="option-btn" onclick="selectOption(6, 'MENYALA', this)">A. MENYALA</button>
            <button class="option-btn" onclick="selectOption(6, 'MATI', this)">B. MATI</button>
        </div>
    </div>

    <div class="question-card" id="q7">
        <h2>№ 3 (Level 2): Struktur 4 Angka</h2>
        <p class="instruction">Susunlah angka-angka <b>21, 15, 14, 6</b> dalam lingkaran agar setiap tanda panah mengalir dari angka <b>TERBESAR ke TERKECIL</b>.</p>
        <div class="circle-layout">
            <div class="circle-box" id="box_l2_tl"><span>Top-Left (Banyak Keluar)</span><input type="number" id="l2_sort_tl"></div>
            <div class="circle-box" id="box_l2_tr"><span>Top-Right</span><input type="number" id="l2_sort_tr"></div>
            <div class="circle-box" id="box_l2_bl"><span>Bottom-Left</span><input type="number" id="l2_sort_bl"></div>
            <div class="circle-box" id="box_l2_br"><span>Bottom-Right (Banyak Masuk)</span><input type="number" id="l2_sort_br"></div>
        </div>
    </div>

    <div class="question-card" id="q8">
        <h2>№ 4 (Level 2): Pola Hubungan Bentuk</h2>
        <p class="instruction">Berdasarkan pola: Jumlah dua lingkaran menghasilkan nilai kotak di antaranya. Berapakah nilai kotak kosong yang berada di sisi kanan di antara lingkaran bernilai 10 dan 50?</p>
        <div class="math-item" id="box_l2_pattern" style="justify-content: center; gap: 15px;">
            <span>Isi Kotak Kosong:</span>
            <input type="number" id="l2_box_pattern">
        </div>
    </div>

    <div class="question-card" id="q9">
        <h2>№ 5 (Level 2): Analisis Kata</h2>
        <p class="instruction">Hitunglah setiap huruf dalam kosakata di bawah ini. Huruf manakah yang paling sering muncul?<br>
        <b>APPLE, PENCIL, ERASER, AIRPLANE, ELEPHANT, BANANA, PIG</b></p>
        <div class="options-container" id="opts_q9">
            <button class="option-btn" onclick="selectOption(9, 'E', this)">(A) E</button>
            <button class="option-btn" onclick="selectOption(9, 'P', this)">(B) P</button>
            <button class="option-btn" onclick="selectOption(9, 'A', this)">(C) A</button>
        </div>
    </div>

    <div class="question-card" id="q10">
        <h2>№ 1 (Level 3): Tantangan Jaringan 5 Angka</h2>
        <p class="instruction">Susunlah angka-angka <b>24, 21, 15, 14, 6</b> ke dalam lingkaran yang tepat dari angka terbesar ke terkecil sesuai alur panah.</p>
        <div class="circle-layout" style="flex-wrap: wrap;">
            <div class="circle-box" id="box_l3_s1"><span>Paling Kiri-Bawah (Keluar Semua)</span><input type="number" id="l3_s1"></div>
            <div class="circle-box" id="box_l3_s2"><span>Kiri-Atas</span><input type="number" id="l3_s2"></div>
            <div class="circle-box" id="box_l3_s3"><span>Tengah</span><input type="number" id="l3_s3"></div>
            <div class="circle-box" id="box_l3_s4"><span>Kanan-Bawah</span><input type="number" id="l3_s4"></div>
            <div class="circle-box" id="box_l3_s5"><span>Paling Kanan-Atas (Masuk Semua)</span><input type="number" id="l3_s5"></div>
        </div>
    </div>

    <div class="question-card" id="q11">
        <h2>№ 2 (Level 3): Pola Simbol Berulang</h2>
        <p class="instruction">Berdasarkan deret pola berikut, simbol manakah yang harus diisi untuk menggantikan tanda "?" ?<br>
        <b style="font-size: 1.3rem; letter-spacing: 3px;">Ο Χ Δ Δ Ο Χ Δ Δ ?</b></p>
        <div class="options-container" id="opts_q11">
            <button class="option-btn" onclick="selectOption(11, 'O', this)">A. Ο (Lingkaran)</button>
            <button class="option-btn" onclick="selectOption(11, 'X', this)">B. Χ (Silang)</button>
            <button class="option-btn" onclick="selectOption(11, 'D', this)">C. Δ (Segitiga)</button>
        </div>
    </div>

    <div class="question-card" id="q12">
        <h2>№ 3 (Level 3): Pola Angka Segitiga</h2>
        <p class="instruction">Temukan polanya: (Kiri + Kanan) - Bawah = Angka Tengah.<br>
        Gunakan aturan tersebut untuk Segitiga ke-3 dengan data bagian Luar = [9, 14, 10]. Berapa nilai "?" di tengah?</p>
        <div class="math-item" id="box_l3_triangle" style="justify-content: center; gap: 15px;">
            <span>Nilai "?" :</span>
            <input type="number" id="l3_triangle_inner">
        </div>
    </div>

    <div class="question-card" id="q13">
        <h2>№ 4 (Level 3): Pola Matriks Visual</h2>
        <p class="instruction">Melihat kecenderungan pengurangan kotak hitam di Baris ke-3: Gambar ke-1 (5 kotak), Gambar ke-2 (4 kotak). Pilihan mana yang merupakan kelanjutan gambar ke-3 dengan sisa kotak yang tepat?</p>
        <div class="options-container" id="opts_q13">
            <button class="option-btn" onclick="selectOption(13, 'A', this)">Pilihan (A) - Sisa 3 Kotak</button>
            <button class="option-btn" onclick="selectOption(13, 'B', this)">Pilihan (B)</button>
            <button class="option-btn" onclick="selectOption(13, 'C', this)">Pilihan (C)</button>
            <button class="option-btn" onclick="selectOption(13, 'D', this)">Pilihan (D)</button>
        </div>
    </div>

    <div class="question-card" id="q14">
        <h2>№ 5 (Level 3): Rute Stasiun Kereta Lokal</h2>
        <p class="instruction">Sebuah kereta berangkat dari Stasiun A (1) ke Stasiun J (10). Jika kereta lokal harus berhenti di seluruh stasiun di antara keberangkatan dan tujuan, berapa kalikah kereta tersebut berhenti?</p>
        <div class="math-item" id="box_l3_train" style="justify-content: center; gap: 15px;">
            <span>Jumlah Berhenti:</span>
            <input type="number" id="l3_train_stop">
        </div>
    </div>

    <div id="feedback-info" class="feedback-banner"></div>

    <div class="results-screen" id="results">
        <h1>🎉 Tantangan Selesai! 🎉</h1>
        <p>Evaluasi selesai! Performa kamu dalam menyelesaikan lembar kerja:</p>
        <h2>Total Skor: <span id="final-score" style="color: var(--success);">0</span> / 100</h2>
        <button class="btn-action" onclick="location.reload()" style="margin-top: 20px;">Main Lagi</button>
    </div>

    <div class="actions" id="action-area">
        <button id="main-action-btn" class="btn-action" onclick="handleButtonClick()">Cek Jawaban</button>
    </div>
</div>

<script>
    let currentStep = 1;
    let totalScore = 0;
    let isCheckedState = false; // Menandai apakah sedang di fase review jawaban atau isi soal
    let selectedAnswers = {}; // Menyimpan pilihan jawaban klik ganda

    const levelNames = {
        1: "LEVEL 1: BASIC", 2: "LEVEL 1: BASIC", 3: "LEVEL 1: BASIC", 4: "LEVEL 1: BASIC",
        5: "LEVEL 2: STANDARD", 6: "LEVEL 2: STANDARD", 7: "LEVEL 2: STANDARD", 8: "LEVEL 2: STANDARD", 9: "LEVEL 2: STANDARD",
        10: "LEVEL 3: CHALLENGE", 11: "LEVEL 3: CHALLENGE", 12: "LEVEL 3: CHALLENGE", 13: "LEVEL 3: CHALLENGE", 14: "LEVEL 3: CHALLENGE"
    };

    function selectOption(qStep, val, element) {
        if (isCheckedState) return; // Kunci pilihan jika sudah dicek
        selectedAnswers[qStep] = val;
        
        const container = element.parentElement;
        Array.from(container.children).forEach(btn => btn.classList.remove('selected'));
        element.classList.add('selected');
    }

    function handleButtonClick() {
        if (!isCheckedState) {
            checkCurrentAnswer();
        } else {
            nextQuestion();
        }
    }

    function checkCurrentAnswer() {
        let isCorrect = false;
        let pointsEarned = 0;
        let feedbackMessage = "";

        if (currentStep === 1) {
            let correctCount = 0;
            const answers = { q1:62, q2:35, q3:69, q4:47, q5:69, q6:35, q7:45, q8:25, q9:20, q10:43 };
            Object.keys(answers).forEach((key, idx) => {
                let inputElement = document.getElementById(`l1_${key}`);
                let boxElement = document.getElementById(`box_l1_${key}`);
                if (parseInt(inputElement.value) === answers[key]) {
                    correctCount++;
                    boxElement.classList.add('correct');
                } else {
                    boxElement.classList.add('wrong');
                }
                inputElement.disabled = true;
            });
            pointsEarned = Math.round((correctCount / 10) * 7);
            isCorrect = correctCount === 10;
            feedbackMessage = `Kamu menjawab benar ${correctCount} dari 10 perhitungan dasar. (+${pointsEarned} Skor)`;
        } 
        else if (currentStep === 2) {
            let t = parseInt(document.getElementById('l1_sort_top').value);
            let b = parseInt(document.getElementById('l1_sort_bottom').value);
            let r = parseInt(document.getElementById('l1_sort_right').value);
            
            document.querySelectorAll('#q2 input').forEach(el => el.disabled = true);
            if (t === 26 && b === 14 && r === 4) {
                isCorrect = true; pointsEarned = 7;
                feedbackMessage = "Luar biasa! Aliran angka dari yang terbesar (26 -> 14 -> 4) tepat.";
            } else {
                feedbackMessage = "Salah. Urutan yang benar dari atas ke bawah ke kanan: 26, 14, 4.";
                document.getElementById('q2').querySelectorAll('.circle-box').forEach(el => el.style.borderColor = 'var(--danger)');
            }
        } 
        else if (currentStep === 3) {
            let ans = parseInt(document.getElementById('l1_animal_sum').value);
            document.getElementById('l1_animal_sum').disabled = true;
            if (ans === 48) {
                isCorrect = true; pointsEarned = 7;
                feedbackMessage = "Tepat sekali! Zebra(20) + Bebek(4) + Rakun(6) + Singa(18) = 48.";
                document.getElementById('box_l1_animal').classList.add('correct');
            } else {
                feedbackMessage = "Kurang tepat. Jawaban yang benar adalah 48.";
                document.getElementById('box_l1_animal').classList.add('wrong');
            }
        } 
        else if (currentStep === 4) {
            let ans = parseInt(document.getElementById('l1_missing_digit').value);
            document.getElementById('l1_missing_digit').disabled = true;
            if (ans === 4) {
                isCorrect = true; pointsEarned = 7;
                feedbackMessage = "Benar! 65 - 34 = 31. Digit yang hilang adalah 4.";
                document.getElementById('box_l1_missing').classList.add('correct');
            } else {
                feedbackMessage = "Salah. Digit yang pas adalah 4.";
                document.getElementById('box_l1_missing').classList.add('wrong');
            }
        } 
        else if (currentStep === 5) {
            let correctCount = 0;
            const answers = { q1:85, q2:57, q3:85, q4:25, q5:93, q6:90, q7:48, q8:28, q9:44, q10:48, q11:41, q12:83, q13:49, q14:83 };
            Object.keys(answers).forEach((key) => {
                let inputElement = document.getElementById(`l2_${key}`);
                let boxElement = document.getElementById(`box_l2_${key}`);
                if (parseInt(inputElement.value) === answers[key]) {
                    correctCount++;
                    boxElement.classList.add('correct');
                } else {
                    boxElement.classList.add('wrong');
                }
                inputElement.disabled = true;
            });
            pointsEarned = Math.round((correctCount / 14) * 7);
            isCorrect = correctCount === 14;
            feedbackMessage = `Benar ${correctCount} dari 14 operasi standard. (+${pointsEarned} Skor)`;
        } 
        else if (currentStep === 6) {
            let selected = selectedAnswers[6];
            highlightMCQ('opts_q6', 'MENYALA', selected);
            if (selected === 'MENYALA') {
                isCorrect = true; pointsEarned = 7;
                feedbackMessage = "Benar! Total ditekan 22 kali (genap), maka status sakelar kembali ke asal (MENYALA).";
            } else {
                feedbackMessage = "Salah. Karena ditekan total genap kali (22 kali), posisinya tetap MENYALA.";
            }
        } 
        else if (currentStep === 7) {
            let tl = parseInt(document.getElementById('l2_sort_tl').value);
            let tr = parseInt(document.getElementById('l2_sort_tr').value);
            let bl = parseInt(document.getElementById('l2_sort_bl').value);
            let br = parseInt(document.getElementById('l2_sort_br').value);
            document.querySelectorAll('#q7 input').forEach(el => el.disabled = true);
            if(tl === 21 && tr === 15 && bl === 14 && br === 6) {
                isCorrect = true; pointsEarned = 7;
                feedbackMessage = "Hebat! Struktur posisi aliran (21 &rarr; 15 &rarr; 14 &rarr; 6) terkonfigurasi dengan benar.";
            } else {
                feedbackMessage = "Salah. Susunan logisnya dari kiri ke kanan adalah: TL=21, TR=15, BL=14, BR=6.";
            }
        } 
        else if (currentStep === 8) {
            let ans = parseInt(document.getElementById('l2_box_pattern').value);
            document.getElementById('l2_box_pattern').disabled = true;
            if(ans === 60) {
                isCorrect = true; pointsEarned = 7;
                feedbackMessage = "Benar! Kotak di antara lingkaran 10 dan 50 didapatkan dari 10 + 50 = 60.";
                document.getElementById('box_l2_pattern').classList.add('correct');
            } else {
                feedbackMessage = "Salah. Jawaban berpola penjumlahan ini adalah 60.";
                document.getElementById('box_l2_pattern').classList.add('wrong');
            }
        } 
        else if (currentStep === 9) {
            let selected = selectedAnswers[9];
            highlightMCQ('opts_q9', 'A', selected);
            if (selected === 'A') {
                isCorrect = true; pointsEarned = 7;
                feedbackMessage = "Benar! Huruf 'A' muncul sebanyak 7 kali dalam seluruh kata tersebut.";
            } else {
                feedbackMessage = "Salah. Huruf yang paling dominan muncul adalah A.";
            }
        } 
        else if (currentStep === 10) {
            let s1 = parseInt(document.getElementById('l3_s1').value);
            let s2 = parseInt(document.getElementById('l3_s2').value);
            let s3 = parseInt(document.getElementById('l3_s3').value);
            let s4 = parseInt(document.getElementById('l3_s4').value);
            let s5 = parseInt(document.getElementById('l3_s5').value);
            document.querySelectorAll('#q10 input').forEach(el => el.disabled = true);
            if(s1 === 24 && s2 === 21 && s3 === 15 && s4 === 14 && s5 === 6) {
                isCorrect = true; pointsEarned = 8;
                feedbackMessage = "Sempurna! Kamu sukses mengurai jaringan 5 lingkaran dari 24 sampai ke 6.";
            } else {
                feedbackMessage = "Salah. Alur urutan dari sumber ke muara akhir: 24, 21, 15, 14, 6.";
            }
        } 
        else if (currentStep === 11) {
            let selected = selectedAnswers[11];
            highlightMCQ('opts_q11', 'O', selected);
            if (selected === 'O') {
                isCorrect = true; pointsEarned = 8;
                feedbackMessage = "Benar! Siklus berulang setiap 4 simbol (O, X, Δ, Δ). Pola ke-9 kembali ke O.";
            } else {
                feedbackMessage = "Salah. Pola berulang mengindikasikan tanda tanya berisi O.";
            }
        } 
        else if (currentStep === 12) {
            let ans = parseInt(document.getElementById('l3_triangle_inner').value);
            document.getElementById('l3_triangle_inner').disabled = true;
            if (ans === 13) {
                isCorrect = true; pointsEarned = 8;
                feedbackMessage = "Benar! Operasi hitungnya: (9 + 14) - 10 = 13.";
                document.getElementById('box_l3_triangle').classList.add('correct');
            } else {
                feedbackMessage = "Salah. Pola menghasilkan nilai tengah sebesar 13.";
                document.getElementById('box_l3_triangle').classList.add('wrong');
            }
        } 
        else if (currentStep === 13) {
            let selected = selectedAnswers[13];
            highlightMCQ('opts_q13', 'A', selected);
            if (selected === 'A') {
                isCorrect = true; pointsEarned = 8;
                feedbackMessage = "Benar! Pola gambar berkurang secara bertahap sehingga pilihan (A) paling akurat.";
            } else {
                feedbackMessage = "Salah. Kelanjutan matriks visual yang benar adalah Pilihan (A).";
            }
        } 
        else if (currentStep === 14) {
            let ans = parseInt(document.getElementById('l3_train_stop').value);
            document.getElementById('l3_train_stop').disabled = true;
            if (ans === 8) {
                isCorrect = true; pointsEarned = 5;
                feedbackMessage = "Tepat sekali! Stasiun antaranya ada 8 (Stasiun 2, 3, 4, 5, 6, 7, 8, dan 9).";
                document.getElementById('box_l3_train').classList.add('correct');
            } else {
                feedbackMessage = "Salah. Kereta berhenti di 8 stasiun perantara.";
                document.getElementById('box_l3_train').classList.add('wrong');
            }
        }

        // Tampilkan Banner Evaluasi Langsung
        const banner = document.getElementById('feedback-info');
        banner.innerText = feedbackMessage;
        banner.className = isCorrect ? 'feedback-banner show-correct' : 'feedback-banner show-wrong';

        // Update total skor
        totalScore += pointsEarned;
        document.getElementById('live-score').innerText = Math.round(totalScore);

        // Ubah state tombol aksi menjadi lanjut
        isCheckedState = true;
        const mainBtn = document.getElementById('main-action-btn');
        mainBtn.innerText = "Lanjut ➔";
        mainBtn.classList.add('next-state');
    }

    function highlightMCQ(containerId, correctVal, chosenVal) {
        const buttons = document.getElementById(containerId).children;
        Array.from(buttons).forEach(btn => {
            if (btn.innerText.includes(correctVal) || (containerId==='opts_q13' && correctVal==='A' && btn.innerText.includes('Pilihan (A)'))) {
                btn.classList.add('correct-opt');
            } else if (btn.classList.contains('selected') && chosenVal !== correctVal) {
                btn.classList.add('wrong-opt');
            }
        });
    }

    function nextQuestion() {
        // Sembunyikan banner evaluasi
        document.getElementById('feedback-info').className = 'feedback-banner';

        // Ganti kartu soal
        document.getElementById(`q${currentStep}`).classList.remove('active');
        currentStep++;

        // Reset state tombol aksi kembali ke mode cek
        isCheckedState = false;
        const mainBtn = document.getElementById('main-action-btn');
        mainBtn.innerText = "Cek Jawaban";
        mainBtn.classList.remove('next-state');

        if (currentStep <= 14) {
            document.getElementById(`q${currentStep}`).classList.add('active');
            document.getElementById('level-indicator').innerText = levelNames[currentStep];
        } else {
            // Selesai seluruh tahapan game
            document.getElementById('level-indicator').style.display = 'none';
            document.getElementById('action-area').style.display = 'none';
            document.getElementById('results').style.display = 'block';
            document.getElementById('final-score').innerText = Math.round(totalScore);
        }
    }
</script>
</body>
</html>
